{
  "name": "oslab",
  "version": "0.3.0",
  "description": "SUERC portable OSL reader data processor",
  "author": "Ariel Chinn",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:electron": "cross-env VITE_BUILD_TARGET=electron vite build",
    "electron:compile": "esbuild electron/main.ts electron/preload.ts --platform=node --format=cjs --bundle --external:electron --out-extension:.js=.cjs --outdir=dist/compiled",
    "preview": "vite preview",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "npm run electron:compile && concurrently \"vite\" \"wait-on http://localhost:5173 && NODE_ENV=development electron .\"",
    "generate-icons": "node scripts/generate-icons.mjs",
    "electron:build": "npm run generate-icons && npm run build:electron && npm run electron:compile && electron-builder --config electron-builder.config.cjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "main": "dist/compiled/main.cjs",
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
